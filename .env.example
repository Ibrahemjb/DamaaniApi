# Use Uid= and Pwd= (not User= — MySQL connectors ignore User= and connect with no password)
DB_CONNECTION_STRING=Server=localhost;Port=3306;Database=dammani;Uid=root;Pwd=password;AllowUserVariables=true;
LISTENING_URL=http://0.0.0.0:5000
JWT_ISSUER_URL=
JWT_ISSUER=damaani-api
JWT_APP_IDENTIFIER=dammani-api
JWT_SECRET=replace-with-at-least-32-characters-local-secret
JWT_LIFETIME_HOURS=72
APP_BASE_URL=http://localhost:5173
# Promote an existing user to platform admin on startup (sign up first, then set email and restart).
PLATFORM_ADMIN_EMAIL=
